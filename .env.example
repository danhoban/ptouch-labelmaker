# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
# FLASK_DEBUG=false

# ── Label store ───────────────────────────────────────────────────────────────
# Uncomment to store labels outside the project directory.
# LABEL_STORE_DIR=/path/to/label_store

# ── Homebox API (optional) ────────────────────────────────────────────────────
# When set, the Homebox webhook endpoint fetches full item data from the API
# and makes all fields available as {{placeholders}} in label templates.
# HOMEBOX_URL=http://your-homebox-instance:7745
# HOMEBOX_API_KEY=hb_your_api_key_here
